# File name
file_name = "sample.txt"

# 1️⃣ Write to a file (Overwrites if file already exists)
with open(file_name, "w") as file:
    file.write("Hello, this is the first line.\n")
    file.write("This file is created using Python.\n")

print("Data written successfully.\n")

# 2️⃣ Read the entire file
with open(file_name, "r") as file:
    content = file.read()
    print("Reading entire file:")
    print(content)

# 3️⃣ Append data to the file
with open(file_name, "a") as file:
    file.write("This line is appended later.\n")

print("\nData appended successfully.\n")

# 4️⃣ Read file line by line
with open(file_name, "r") as file:
    print("Reading file line by line:")
    for line in file:
        print(line.strip())

# 5️⃣ Other operations
import os

print("\nOther File Operations:")
print("File exists:", os.path.exists(file_name))
print("File size:", os.path.getsize(file_name), "bytes")

